<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:text="📷"
            android:textSize="56sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:text="Ghar CCTV"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:text="Background Camera Streamer"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1c1c1e"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:text="STATUS"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:text="Band hai — Start karo"
                android:textSize="16sp"
                android:textColor="#4ade80"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- IP Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1c1c1e"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvIp"
                android:text="Phone IP: —"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvUrl"
                android:text="Phone 2 me ye URL kholo:\nhttp://—:8080"
                android:textSize="16sp"
                android:textColor="#60a5fa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

        <Button
            android:id="@+id/btnStart"
            android:text="▶  Camera Shuru Karo"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="#2563eb"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnStop"
            android:text="■  Band Karo"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="#dc2626"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Tips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1c1c1e"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:text="📋  Setup Guide"
                android:textSize="14sp"
                android:textColor="#cccccc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:text="1. Camera Shuru Karo (ek baar)\n2. IP/URL upar dikhegi\n3. Phone 2 me Chrome me URL daalo\n4. Ab app band karo — background me chalti rahegi\n5. Phone restart hone par bhi auto-start hogi"
                android:textSize="13sp"
                android:textColor="#888888"
                android:lineSpacingMultiplier="1.5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
